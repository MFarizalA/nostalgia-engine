# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is excluded from git — never commit secrets.

# ── Alibaba Cloud credentials ────────────────────────────────────────────────
access_key = "LTAI5t..."
secret_key = "xxxxxxxxxxxxxxxxxxxxxx"
region     = "cn-hangzhou"

# ── Model Studio ─────────────────────────────────────────────────────────────
dashscope_api_key = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── OSS ──────────────────────────────────────────────────────────────────────
# Must be globally unique across all of Alibaba Cloud OSS
oss_bucket_name = "nostalgia-engine-outputs-yourname"

# ── SAS instance ─────────────────────────────────────────────────────────────
sas_instance_name = "doge-nostalgia-engine"

# Find your region's plan ID:
#   tofu console  →  data.alicloud_simple_application_server_server_plans.all.plans
# 2 vCPU / 4 GB example (cn-hangzhou):
sas_plan_id = "swas.s2.medium.1"

# Leave empty to auto-select the first Ubuntu 22.04 image, or set explicitly:
# sas_image_id = "ubuntu_22_04_x64_20G_alibase_20240819.vhd"

sas_period    = 1      # months
key_pair_name = "my-sas-keypair"   # must already exist in the console

# ── App repo ──────────────────────────────────────────────────────────────────
git_repo_url = "https://github.com/your-org/nostalgia-engine.git"
